rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' || 
        (request.auth.token.email == "smit.zaveri@bugasura.io" && request.auth.token.email_verified == true)
      );
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && request.resource.data.role == 'civilian';
      allow update: if isAdmin() || (isOwner(uid) && request.resource.data.role == resource.data.role);
    }

    match /incidents/{incidentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if hasRole('responder') || hasRole('admin');
      allow delete: if isAdmin();
    }

    match /dispatches/{dispatchId} {
      allow read: if hasRole('responder') || hasRole('admin');
      allow create: if hasRole('responder') || hasRole('admin');
      allow update: if hasRole('responder') || hasRole('admin');
    }

    match /medicalRecords/{recordId} {
      allow read: if isOwner(resource.data.userId) || hasRole('nurse') || hasRole('admin');
      allow create: if isAuthenticated();
      allow update: if hasRole('nurse') || hasRole('admin');
    }
  }
}
